# devbox の direnv 連携を有効化 (jdk 等を PATH に通す)
eval "$(devbox generate direnv --print-envrc)"

# 秘密情報はローカルの .env から読み込む (.env はコミットしない)
dotenv_if_exists .env

# Android SDK は devbox 外で管理する (scripts/setup_android.sh で導入)
export ANDROID_HOME="$HOME/Android/Sdk"
PATH_add "$ANDROID_HOME/platform-tools"
PATH_add "$ANDROID_HOME/cmdline-tools/latest/bin"
PATH_add "$ANDROID_HOME/emulator"
