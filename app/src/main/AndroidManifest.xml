<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Wear OS 専用アプリ。スマホ側コンパニオンは持たない -->
    <uses-feature android:name="android.hardware.type.watch" />

    <!-- フェーズ遷移はすべて振動で通知する -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Health Services 経由の心拍取得 (実行時許可) -->
    <uses-permission android:name="android.permission.BODY_SENSORS" />

    <application
        android:label="@string/app_name"
        android:theme="@android:style/Theme.DeviceDefault">

        <!-- スマホアプリ無しで単体動作する宣言 -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="true" />

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 開発用の設定書き込み (debuggable ビルド以外では無効。実装側でガード) -->
        <receiver
            android:name=".settings.DebugConfigReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="io.github.wakuwaku3.adaptivepulse.SET_CONFIG" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
