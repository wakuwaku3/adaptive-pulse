<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Wear OS 専用アプリ。スマホ側コンパニオンは持たない -->
    <uses-feature android:name="android.hardware.type.watch" />

    <!-- フェーズ遷移はすべて振動で通知する -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Health Services 経由の心拍取得 (実行時許可) -->
    <uses-permission android:name="android.permission.BODY_SENSORS" />

    <!-- カロリー累計の取得に必要 (実行時許可。拒否時はカロリー無しで計測継続) -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />

    <!-- 画面オフ中の計測継続 (Foreground Service)。通知許可は API 33+ で実行時要求 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_HEALTH" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:label="@string/app_name"
        android:theme="@android:style/Theme.DeviceDefault">

        <!-- スマホアプリ無しで単体動作する宣言 -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="true" />

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".session.SessionService"
            android:exported="false"
            android:foregroundServiceType="health" />

        <!-- phone 起点の設定変更を受信する (Wearable Data Layer) -->
        <service
            android:name=".sync.WatchSyncService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <data
                    android:scheme="wear"
                    android:host="*"
                    android:pathPrefix="/settings" />
            </intent-filter>
        </service>

        <!-- ウォッチフェイスから 1 スワイプで開始するタイル -->
        <service
            android:name=".tile.MainTileService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@drawable/ic_pulse" />
        </service>

        <!-- 開発用の設定書き込み (debuggable ビルド以外では無効。実装側でガード) -->
        <receiver
            android:name=".settings.DebugConfigReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="io.github.wakuwaku3.adaptivepulse.SET_CONFIG" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
