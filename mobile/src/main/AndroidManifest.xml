<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- サーバー同期 (Firebase Auth / 同期 API) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- watch のセッション開始通知 + ライブ画面の自動起動。
         Android 13+ は通知に実行時許可、Android 14+ は full-screen intent にユーザ許可が要る -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- Health Connect から日次の健康指標を読む。Pixel Watch / 体重計 / あすけん が
         Health Connect に書いているのを読みに行く片方向 read のみ。
         実際に grant してもらう権限は HealthDataSource の Activity Result で要求する -->
    <uses-permission android:name="android.permission.health.READ_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_RESTING_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE_VARIABILITY" />
    <uses-permission android:name="android.permission.health.READ_SLEEP" />
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_ACTIVE_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_TOTAL_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_EXERCISE" />
    <uses-permission android:name="android.permission.health.READ_WEIGHT" />
    <uses-permission android:name="android.permission.health.READ_BODY_FAT" />
    <uses-permission android:name="android.permission.health.READ_LEAN_BODY_MASS" />
    <uses-permission android:name="android.permission.health.READ_HEIGHT" />
    <uses-permission android:name="android.permission.health.READ_NUTRITION" />
    <!-- ダッシュボード拡張: Google Health で見える主要指標を全部 phone 側で表示するため
         追加で読む。Pixel Watch / Asken / 体組成計が書く範囲をカバーする
         (docs/notes/20260620__dashboard-redesign/index.md) -->
    <uses-permission android:name="android.permission.health.READ_DISTANCE" />
    <uses-permission android:name="android.permission.health.READ_FLOORS_CLIMBED" />
    <uses-permission android:name="android.permission.health.READ_ELEVATION_GAINED" />
    <uses-permission android:name="android.permission.health.READ_OXYGEN_SATURATION" />
    <uses-permission android:name="android.permission.health.READ_RESPIRATORY_RATE" />
    <uses-permission android:name="android.permission.health.READ_SKIN_TEMPERATURE" />
    <uses-permission android:name="android.permission.health.READ_BASAL_METABOLIC_RATE" />
    <!-- 過去 30 日より前のデータを読むには Android 14+ で別途必要。
         初回 5 年同期 (HealthSyncWorker) のためにリクエストする。拒否時は HC が 30 日で打ち切る -->
    <uses-permission android:name="android.permission.health.READ_HEALTH_DATA_HISTORY" />

    <!-- 本アプリを HC のカロリー master にする (docs/stock/health-data-export.md)。
         日次の自前 TDEE を TotalCaloriesBurnedRecord として 1 レコード/日 で upsert し、
         他アプリ (Google Fit / MyFitnessPal 等) もこちらの値を読めるようにする -->
    <uses-permission android:name="android.permission.health.WRITE_TOTAL_CALORIES_BURNED" />

    <!-- Android 11+ の package visibility 制限を解き、Health Connect の存在判定と
         権限ダイアログ起動を可能にする -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
        <intent>
            <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
        </intent>
    </queries>

    <application
        android:name=".AdaptivePulseApplication"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@android:style/Theme.Material.NoActionBar">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Android 13 以前の Health Connect (Play ストア配信版) はこの intent で
                 rationale activity を解決する。Android 14+ は下の activity-alias を使う -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
        </activity>

        <!-- Android 14+ の OS 統合版 Health Connect はこの intent-filter で rationale を
             解決する。これが無いと HC の PermissionsActivity が「App should support
             rationale intent, finishing!」で即終了し、権限ダイアログが出ない。
             専用画面は持たず MainActivity に飛ばす (設定トグル + 説明文で十分) -->
        <activity-alias
            android:name=".ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

        <!-- Health Connect から取り込んだ JSON エクスポートを他アプリと共有するための FileProvider。
             authorities は applicationId に依存させて衝突を避ける -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- watch からの履歴・設定・ライブ状態 + セッション開始 ping を受信する (Wearable Data Layer) -->
        <service
            android:name=".sync.PhoneSyncService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <data
                    android:scheme="wear"
                    android:host="*"
                    android:pathPrefix="/sessions" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <data
                    android:scheme="wear"
                    android:host="*"
                    android:pathPrefix="/settings" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <data
                    android:scheme="wear"
                    android:host="*"
                    android:pathPrefix="/session/live" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data
                    android:scheme="wear"
                    android:host="*"
                    android:pathPrefix="/session/start-foreground" />
            </intent-filter>
        </service>
    </application>

</manifest>
